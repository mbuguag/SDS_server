DATABASE_URL=postgresql://postgres:replace_password@localhost:5432/smoothtel_db
JWT_SECRET=replace_with_a_long_random_secret
PORT=4000
NODE_ENV=development

# Mail
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=replace_with_smtp_user
